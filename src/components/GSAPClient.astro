	// card slider

	function createCardSlider(selector, options = {}) {
		const {
			delay = 4000,
			distortionScale = 30
		} = options;

		const root = document.querySelector(selector);
		const slides = root.querySelectorAll(".cardimg");
		const displacement = root.querySelector("feDisplacementMap");

		let current = 0;
		let isAnimating = false;
		let timeout = null;

		// próxima transição
		function next() {
			if (isAnimating) return;
			isAnimating = true;

			const nextIndex = (current + 1) % slides.length;

			const tl = gsap.timeline({
				onComplete: () => {
					slides[current].classList.remove("active");
					slides[nextIndex].classList.add("active");

					gsap.set(slides[current], { opacity: 0 });

					current = nextIndex;
					isAnimating = false;
				}
			});

			gsap.set(slides[nextIndex], { opacity: 1 });

			tl.to(displacement, {
				attr: { scale: distortionScale },
				duration: 0.3,
				ease: "power2.out"
			});

			tl.to(slides[current], {
				opacity: 0,
				duration: 0.5
			}, "<");

			tl.to(displacement, {
				attr: { scale: 0 },
				duration: 0.2,
				ease: "power2.in"
			});
		}

		function play() {
			stop();
			// console.log("PLAY");

			timeout = setTimeout(() => {
				// console.log("AUTO NEXT");
				next();
				play();
			}, delay);
		}

		function stop() {
			// console.log("STOP");
			if (timeout) {
				clearTimeout(timeout);
				timeout = null;
			}
		}

		function reset() {
			play();
		}

		// eventos
		function bindEvents() {
			root.addEventListener("click", () => {
				if (isAnimating) return;

				stop();
				next();
				// play();
			});

			root.addEventListener("pointerenter", stop);
			root.addEventListener("pointerleave", play);
		}

		// init
		function init() {
			if (!root || slides.length === 0) return;

			bindEvents();
			play();

			// animação contínua do ruído
			gsap.to(root.querySelector("feTurbulence"), {
				attr: { baseFrequency: 0.008 },
				yoyo: true,
				repeat: -1,
				duration: 6
			});
		}

		return { init, next, stop, play };
	}

	createCardSlider("#cardslider").init();








	// carousel

	class Carousel {
	  constructor(element) {
	    this.el = element;
	    this.track = this.el.querySelector(".carousel-track");
	    this.slides = Array.from(this.el.querySelectorAll(".slide"));
	    this.dotsContainer = this.el.querySelector(".carousel-dots");

	    this.index = 0;
	    this.lastPreloadIndex = null;

	    this.init();
	  }

	  init() {
	    this.calculatePositions();
	    this.createDots();
	    this.createDraggable();

	    this.initLazyLoad();
	    this.initVideoControls();
	    this.initProgressBars();

	    this.preloadVideos();

	    window.addEventListener("resize", () => this.calculatePositions());
	    window.addEventListener("load", () => this.calculatePositions());
	  }

	  // ------------------------
	  // POSITIONS
	  // ------------------------

	  calculatePositions() {
	    const trackRect = this.track.getBoundingClientRect();

	    this.positions = this.slides.map(slide => {
	      const slideRect = slide.getBoundingClientRect();
	      return -(slideRect.left - trackRect.left) + gsap.getProperty(this.track, "x");
	    });
	  }

	  // ------------------------
	  // DOTS
	  // ------------------------

	  createDots() {
	    this.dotsContainer.innerHTML = "";

	    this.dots = this.slides.map((_, i) => {
	      const btn = document.createElement("button");
	      btn.addEventListener("click", () => this.goTo(i));
	      this.dotsContainer.appendChild(btn);
	      return btn;
	    });
	  }

	  updateDots() {
	    this.dots.forEach((dot, i) => {
	      dot.classList.toggle("active", i === this.index);
	    });
	  }

	  // ------------------------
	  // NAVIGATION
	  // ------------------------

	  goTo(i) {
	    this.index = Math.max(0, Math.min(i, this.slides.length - 1));

	    this.preloadVideos();

	    gsap.to(this.track, {
	      x: this.positions[this.index],
	      duration: 0.5,
	      ease: "power2.out"
	    });

	    this.updateDots();
	  }

	  // ------------------------
	  // DRAG
	  // ------------------------

	  createDraggable() {
	    Draggable.create(this.track, {
	      type: "x",
	      inertia: true,
	      bounds: {
	        minX: this.positions[this.positions.length - 1],
	        maxX: 0
	      },
	      throwResistance: 1200,
	      edgeResistance: 0.85,

	      onDrag: () => {
	        this.updateActiveIndex();
	        this.preloadVideos();
	      },

	      onThrowUpdate: () => {
	        this.updateActiveIndex();
	        this.preloadVideos();
	      }
	    });
	  }

	  updateActiveIndex() {
	    const currentX = gsap.getProperty(this.track, "x");

	    let closest = 0;
	    let minDistance = Infinity;

	    this.positions.forEach((pos, i) => {
	      const dist = Math.abs(pos - currentX);
	      if (dist < minDistance) {
	        minDistance = dist;
	        closest = i;
	      }
	    });

	    this.index = closest;
	    this.updateDots();
	  }

	  // ------------------------
	  // LAZY LOAD
	  // ------------------------

	  initLazyLoad() {
	    const observer = new IntersectionObserver(entries => {
	      entries.forEach(entry => {
	        const slide = entry.target;

	        if (entry.isIntersecting) {
	          this.loadMedia(slide);
	          this.playVideo(slide);
	        } else {
	          this.pauseVideo(slide);
	        }
	      });
	    }, {
	      root: this.el,
	      threshold: 0.5
	    });

	    this.slides.forEach(slide => observer.observe(slide));
	  }

	  loadMedia(slide) {
	    // imagens
	    slide.querySelectorAll("img[data-src]").forEach(img => {
	      img.src = img.dataset.src;
	      img.removeAttribute("data-src");
	    });

	    // vídeos
	    const video = slide.querySelector("video");
	    if (video) this.loadVideo(video);
	  }

	  loadVideo(video) {
	    const sources = video.querySelectorAll("source");

	    let needsLoad = false;

	    sources.forEach(source => {
	      if (!source.src && source.dataset.src) {
	        source.src = source.dataset.src;
	        needsLoad = true;
	      }
	    });

	    if (needsLoad) {
	      video.load();
	    }
	  }

	  preloadVideos() {
	    if (this.lastPreloadIndex === this.index) return;

	    this.lastPreloadIndex = this.index;

	    const range = 1;

	    this.slides.forEach((slide, i) => {
	      const video = slide.querySelector("video");
	      if (!video) return;

	      if (Math.abs(i - this.index) <= range) {
	        this.loadVideo(video);
	      }
	    });
	  }

	  // ------------------------
	  // VIDEO CONTROL
	  // ------------------------

	  playVideo(slide) {
	    this.slides.forEach(s => this.pauseVideo(s));

	    const video = slide.querySelector("video");
	    if (!video) return;

	    video.muted = true;
	    video.playsInline = true;

	    video.play().catch(() => {});
	  }

	  pauseVideo(slide) {
	    const video = slide.querySelector("video");
	    if (!video) return;

	    video.pause();
	  }

	  initVideoControls() {
	    this.slides.forEach(slide => {
	      const video = slide.querySelector("video");
	      const button = slide.querySelector(".video-toggle");

	      if (!video || !button) return;

	      button.addEventListener("click", (e) => {
	        e.stopPropagation();

	        if (video.paused) this.playVideo(slide);
	        else this.pauseVideo(slide);
	      });

	      video.addEventListener("pointerdown", e => e.stopPropagation());

	      video.addEventListener("click", () => {
	        if (video.paused) this.playVideo(slide);
	        else this.pauseVideo(slide);
	      });

	      video.addEventListener("play", () => {
	        button.textContent = "⏸";
	        button.classList.add("hidden");
	      });

	      video.addEventListener("pause", () => {
	        button.textContent = "▶";
	        button.classList.remove("hidden");
	      });
	    });
	  }

	  // ------------------------
	  // PROGRESS BAR
	  // ------------------------

	  initProgressBars() {
	    this.slides.forEach(slide => {
	      const video = slide.querySelector("video");
	      const bar = slide.querySelector(".progress-bar");
	      const progress = slide.querySelector(".progress");

	      if (!video || !bar || !progress) return;

	      let update;

	      video.addEventListener("loadedmetadata", () => {
	        video.currentTime = 0;

	        update = () => {
	          if (!video.duration) return;

	          const percent = video.currentTime / video.duration;
	          bar.style.transform = `scaleX(${percent})`;
	        };

	        video.addEventListener("timeupdate", update);
	      });

	      video.addEventListener("emptied", () => {
	        bar.style.transform = "scaleX(0)";
	        if (update) video.removeEventListener("timeupdate", update);
	      });

	      progress.addEventListener("pointerdown", e => e.stopPropagation());

	      progress.addEventListener("click", (e) => {
	        const rect = progress.getBoundingClientRect();
	        const percent = (e.clientX - rect.left) / rect.width;

	        video.currentTime = percent * video.duration;
	      });
	    });
	  }
	}

	// init múltiplos
	document.querySelectorAll("[data-carousel]").forEach(el => {
		new Carousel(el);
	});



