---
import { getLang } from "../../i18n/index.js";

export async function getStaticPaths() {
	return [
		{ params: { lang: 'pt' } },
		{ params: { lang: 'en' } }
	];
}

import BaseLayout from '../../layouts/BaseLayout.astro';
import SlideIMG from '../../components/SlideIMG.astro';
import SlideVideo from '../../components/SlideVideo.astro';
import AnimatedSection from "../../components/AnimatedSection.astro";
import Footer from '../../components/Footer.astro';

const { lang } = Astro.params;
const currentLang = ["en", "pt"].includes(lang) ? lang : "en";

const dict = getLang(currentLang);

const cardImages = [
	"/img/slides/others/ingty-bg.png",
	"/img/slides/others/fictor-card.webp", 
	"/img/slides/vega/vega-card.webp",
	"/img/slides/others/pp-card.png",
	"/img/slides/vega/panfleto3.jpg"
];


