---
const redirectUrl = `${import.meta.env.BASE_URL}pt/`;
---

<html lang="pt">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
		<script>
			window.location.replace('/portfolio/pt/');
		</script>
		<title>Redirecionando...</title>
	</head>
	<body>
		<div class="loader"></div>
		<script>
			window.location.replace(redirectUrl);
		</script>
	</body>
</html>

<style lang="sass">
	body
		background-color: #072F25
		width: 100vw
		height: 100dvh
		display: grid
		place-content: center
		grid-auto-flow: column
		overflow: hidden

	.loader
		width: 50px
		aspect-ratio: 1
		border-radius: 50%
		padding: 3px
		background: radial-gradient(farthest-side,#ffa516 95%,#0000) 50% 0/12px 12px no-repeat, radial-gradient(farthest-side,#0000 calc(100% - 5px),#ffa516 calc(100% - 4px)) content-box
		animation: loader 2s infinite

	@keyframes loader
		to
			transform: rotate(1turn)
</style>